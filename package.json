{
  "name": "mc-server-manager",
  "private": true,
  "version": "0.1.0",
  "description": "Desktop Minecraft server manager.",
  "license": "MIT",
  "author": "NAinfini",
  "type": "module",
  "main": "electron/main.cjs",
  "repository": {
    "type": "git",
    "url": "https://github.com/NAinfini/MCServerManager.git"
  },
  "engines": {
    "node": ">=22.12",
    "pnpm": ">=9"
  },
  "pnpm": {
    "overrides": {
      "dompurify": "3.4.11"
    }
  },
  "scripts": {
    "dev": "vite",
    "tsc": "tsc",
    "build": "tsc && vite build",
    "electron:dev": "concurrently -k \"pnpm dev\" \"wait-on http://localhost:1420 && electron .\"",
    "electron:build": "pnpm build && electron-builder",
    "preview": "vite preview"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.4.0",
    "@monaco-editor/react": "^4.7.0",
    "@radix-ui/react-checkbox": "1.3.3",
    "@radix-ui/react-dialog": "1.1.17",
    "@radix-ui/react-progress": "^1.1.11",
    "@radix-ui/react-select": "2.3.1",
    "@radix-ui/react-separator": "^1.1.11",
    "@radix-ui/react-switch": "1.3.1",
    "@radix-ui/react-tabs": "1.1.15",
    "@radix-ui/react-toggle-group": "^1.1.14",
    "@radix-ui/react-toolbar": "^1.1.14",
    "@radix-ui/react-tooltip": "1.2.10",
    "@tanstack/react-query": "^5.101.2",
    "@xterm/xterm": "^6.0.0",
    "clsx": "^2.1.1",
    "electron-updater": "^6.8.9",
    "lucide-react": "^1.22.0",
    "motion": "12.42.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-hook-form": "^7.80.0",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3",
    "zustand": "5.0.14"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "concurrently": "^9.2.1",
    "electron": "^39.2.7",
    "electron-builder": "^26.0.12",
    "jsdom": "^29.1.1",
    "prettier": "^3.9.4",
    "typescript": "~5.8.3",
    "vite": "^7.0.4",
    "vitest": "^4.1.9",
    "wait-on": "^9.0.3"
  },
  "build": {
    "appId": "com.mcservermanager.desktop",
    "productName": "MC Server Manager",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**",
      "electron/**",
      "!electron/*.test.mjs",
      "public/app-icon.ico",
      "package.json"
    ],
    "win": {
      "artifactName": "MC-Server-Manager-Setup-${version}.${ext}",
      "icon": "public/app-icon.ico",
      "target": "nsis"
    },
    "linux": {
      "artifactName": "MC-Server-Manager-${version}-${arch}.${ext}",
      "category": "Game",
      "target": [
        "AppImage",
        "deb"
      ]
    },
    "mac": {
      "artifactName": "MC-Server-Manager-${version}-${arch}.${ext}",
      "category": "public.app-category.utilities",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "publish": [
      {
        "provider": "github",
        "owner": "NAinfini",
        "repo": "MCServerManager"
      }
    ]
  }
}
